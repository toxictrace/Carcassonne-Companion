<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/battle_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EE111811"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/battle_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚔️ Последняя битва"
            android:textColor="#FFE5E7EB"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/battle_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF9CA3AF"
            android:textSize="10sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/battle_gear"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="⚙"
            android:textColor="#FF4ADE80"
            android:textSize="18sp"
            android:gravity="center"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/battle_photo"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:scaleType="fitCenter"
        android:layout_marginTop="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginTop="4dp"
        android:id="@+id/battle_players_container">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <ImageView android:id="@+id/p1_avatar" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/p1_name" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="11sp" android:textColor="#FF4ADE80"
                android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/p1_score" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FF4ADE80" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <ImageView android:id="@+id/p2_avatar" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/p2_name" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="11sp" android:textColor="#FFE5E7EB"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/p2_score" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FF9CA3AF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <ImageView android:id="@+id/p3_avatar" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/p3_name" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="11sp" android:textColor="#FFE5E7EB"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/p3_score" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FF9CA3AF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <ImageView android:id="@+id/p4_avatar" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/p4_name" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="11sp" android:textColor="#FFE5E7EB"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/p4_score" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FF9CA3AF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <ImageView android:id="@+id/p5_avatar" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/p5_name" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="11sp" android:textColor="#FFE5E7EB"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/p5_score" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FF9CA3AF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:id="@+id/p6_avatar" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/p6_name" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="11sp" android:textColor="#FFE5E7EB"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/p6_score" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FF9CA3AF"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/battle_notes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF9CA3AF"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/battle_share"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="󰖢"
        android:textColor="#FF4ADE80"
        android:textSize="18sp"
        android:gravity="end"
        android:layout_marginTop="2dp"/>

</LinearLayout>
